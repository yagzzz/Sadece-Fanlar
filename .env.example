# ============================================
# SADECE FANLAR - Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayın ve TÜM sırları kendiniz üretin:
#   cp .env.example .env
#
# Güçlü sır üretmek için:
#   openssl rand -hex 32
#
# UYARI: Bu dosyadaki değerler yalnızca ÖRNEKTİR. Gerçek değerleri
# .env dosyasına yazın ve .env dosyasını ASLA git'e eklemeyin.
# ============================================

# ============================================
# DATABASE (güçlü, rastgele bir parola üretin)
# ============================================
DB_PASSWORD=__CHANGE_ME__openssl_rand_hex_32

# ============================================
# REDIS (güçlü, rastgele bir parola üretin)
# ============================================
REDIS_PASSWORD=__CHANGE_ME__openssl_rand_hex_32

# ============================================
# APPLICATION
# ============================================
# openssl rand -hex 32 ile üretin (en az 32 karakter)
SECRET_KEY=__CHANGE_ME__openssl_rand_hex_32
# development | production  (production'da zayıf sırlar reddedilir)
ENVIRONMENT=production
# Virgülle ayırın; production'da yalnızca kendi domain'iniz
CORS_ORIGINS=https://yourdomain.com

# ============================================
# URLS
# ============================================
PUBLIC_API_URL=https://api.yourdomain.com
PUBLIC_WS_URL=wss://api.yourdomain.com
ORIGIN=https://yourdomain.com

# ============================================
# BTCPAY SERVER
# ============================================
BTCPAY_URL=http://btcpay:49392
BTCPAY_API_KEY=__CHANGE_ME__
BTCPAY_STORE_ID=__CHANGE_ME__
BTCPAY_NETWORK=mainnet
# Webhook imzası için secret - boş bırakılırsa webhook'lar REDDEDİLİR (güvenlik)
BTCPAY_WEBHOOK_SECRET=__CHANGE_ME__openssl_rand_hex_32
# Test için "testnet", canlı için "mainnet"

# ============================================
# MONERO
# Yerel monerod çalışmıyor; wallet-rpc uzak (public) bir node'a bağlanır.
# Güvenilir node seçenekleri (istediğini kullan):
#   node.community.rino.io:18089   (RINO - SSL destekli)
#   nodes.hashvault.pro:18081
#   node.sethforprivacy.com:18089
#   xmr-node.cakewallet.com:18081
# Kendi node'unu kurduğunda MONERO_DAEMON_HOST=kendi.ip MONERO_DAEMON_PORT=18081 yap.
# ============================================
MONERO_WALLET_RPC_URL=http://monero-wallet:18083
MONERO_WALLET_RPC_USER=rpc_user
MONERO_WALLET_RPC_PASSWORD=__CHANGE_ME__openssl_rand_hex_32
# Uzak node bağlantısı (monerod servisini kaldırdık, wallet-rpc buna bağlanır)
# Çalışan public node'lar: node.monerodevs.org:18089, xmr-node.cakewallet.com:18081
MONERO_DAEMON_ADDRESS=node.monerodevs.org:18089

# ============================================
# MINIO (S3-compatible storage)
# ============================================
MINIO_ENDPOINT=minio:9000
# Tarayıcıların medyaya (avatar, kapak, içerik) erişebileceği genel adres.
# Geliştirmede http://localhost:9000, production'da örn. https://media.yourdomain.com
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=__CHANGE_ME__
MINIO_SECRET_KEY=__CHANGE_ME__openssl_rand_hex_32
MINIO_BUCKET=sadecefanlar
MINIO_USE_SSL=false

# ============================================
# EMAIL (opsiyonel - anonimlik için önerilmez)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============================================
# STREAMING (opsiyonel - RTMP için)
# ============================================
RTMP_SERVER_URL=rtmp://localhost:1935/live
STREAM_KEY_SECRET=__CHANGE_ME__openssl_rand_hex_32
