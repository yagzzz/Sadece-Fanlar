# ============================================
# SADECE FANLAR - Environment Variables
# ============================================
# Copy this file to .env and customize

# ============================================
# DATABASE
# ============================================
DB_PASSWORD=135790

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=135790

# ============================================
# APPLICATION
# ============================================
SECRET_KEY=your_256_bit_secret_key_generate_with_openssl_rand_hex_32
ENVIRONMENT=production
CORS_ORIGINS=https://yourdomain.com

# ============================================
# URLS
# ============================================
PUBLIC_API_URL=https://api.yourdomain.com
PUBLIC_WS_URL=wss://api.yourdomain.com
ORIGIN=https://yourdomain.com

# ============================================
# BTCPAY SERVER
# ============================================
BTCPAY_URL=http://btcpay:49392
BTCPAY_API_KEY=your_btcpay_api_key
BTCPAY_STORE_ID=your_btcpay_store_id
BTCPAY_NETWORK=mainnet
# Use "testnet" for testing, "mainnet" for production

# ============================================
# MONERO
# ============================================
MONERO_WALLET_RPC_URL=http://monero-wallet:18083
MONERO_WALLET_RPC_USER=rpc_user
MONERO_WALLET_RPC_PASSWORD=super_secure_monero_rpc_password

# ============================================
# MINIO (S3-compatible storage)
# ============================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secure_password
MINIO_BUCKET=sadecefanlar
MINIO_USE_SSL=false

# ============================================
# EMAIL (optional)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# STREAMING (optional - for RTMP)
# ============================================
RTMP_SERVER_URL=rtmp://localhost:1935/live
STREAM_KEY_SECRET=your_stream_key_signing_secret
